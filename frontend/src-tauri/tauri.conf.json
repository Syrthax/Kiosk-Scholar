{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiosk-Scholar",
  "version": "0.1.0",
  "identifier": "com.krisplabs.kiosk-scholar",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kiosk-Scholar",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src ipc: http://ipc.localhost http://127.0.0.1:8000 ws://localhost:1420 ws://127.0.0.1:1420; script-src 'self' blob: 'unsafe-inline'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; worker-src blob: 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
