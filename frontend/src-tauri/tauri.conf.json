{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiosk-Scholar",
  "version": "0.1.0",
  "identifier": "com.ritvik-malhotra.frontend",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kiosk-Scholar",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {}
    
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
